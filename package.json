{
  "name": "tracpoll",
  "version": "1.0.0",
  "description": "Decentralized P2P polling and voting app built on the Intercom stack (Trac Network)",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "pear run .",
    "admin": "pear run . --peer-store-name admin --msb-store-name admin-msb --sidechannels polls",
    "voter": "pear run . --peer-store-name voter1 --msb-store-name voter1-msb --sidechannels polls"
  },
  "keywords": [
    "trac",
    "intercom",
    "p2p",
    "polling",
    "voting",
    "hyperswarm",
    "pear"
  ],
  "license": "MIT",
  "dependencies": {
    "b4a": "^1.6.4",
    "hyperswarm": "^4.7.15",
    "hyperdht": "^6.18.0",
    "autobase": "^6.0.0",
    "hyperbee": "^2.20.5",
    "protomux": "^3.14.0",
    "compact-encoding": "^2.12.0"
  },
  "devDependencies": {},
  "pear": {
    "name": "tracpoll",
    "type": "terminal"
  }
}
